generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(uuid())
  name               String
  email              String   @unique
  cpf                String?  @unique
  phone              String?
  gender             String?
  passwordHash       String
  avatarUrl          String?
  status             UserStatus @default(ACTIVE)
  mustChangePassword Boolean  @default(false)

  onboardingIntent   OnboardingIntent @default(CLIENT)
  onboardingStatus   OnboardingStatus @default(DONE)

  clientLatitude           Decimal?  @db.Decimal(10, 7)
  clientLongitude          Decimal?  @db.Decimal(10, 7)
  clientLocationUpdatedAt  DateTime?

  memberships        BarbershopMembership[]
  barberProfile      BarberProfile?
  createdBlocks      BarberBlock[] @relation("CreatedBlocks")
  barberBlocks       BarberBlock[] @relation("BarberUserBlocks")
  clientAppointments BarbershopAppointment[] @relation("ClientAppointments")
  barberAppointments BarbershopAppointment[] @relation("BarberAppointments")
  canceledAppointments BarbershopAppointment[] @relation("CanceledByUser")
  favoriteBarbershops FavoriteBarbershop[]
  passwordResetTokens  PasswordResetToken[]

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique @db.VarChar(128)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model Barbershop {
  id                 String   @id @default(uuid())

  name               String   @db.VarChar(150)
  description        String?  @db.Text
  phone              String?  @db.VarChar(20)

  address            String?  @db.VarChar(220)
  addressNumber      String?  @db.VarChar(20)
  addressComplement  String?  @db.VarChar(120)
  neighborhood       String?  @db.VarChar(150)
  city               String?  @db.VarChar(120)
  state              String?  @db.VarChar(5)
  zipCode            String?  @db.VarChar(12)

  slug               String?  @unique @db.VarChar(200)

  logoUrl            String?  @db.Text
  coverUrl           String?  @db.Text

  status             BarbershopStatus @default(EM_CONFIGURACAO)
  financialStatus    FinancialStatus  @default(ACTIVE)
  blockedReason      String?          @db.Text
  blockedAt          DateTime?

  suspensionReason   String?   @db.Text
  suspensionUntil    DateTime? @db.Date

  cnpj               String?  @unique @db.VarChar(20)
  cpf                String?  @unique @db.VarChar(20)

  avgPrice           Decimal? @db.Decimal(10, 2)
  avgTimeMinutes     Int?

  facilities         String[]
  paymentMethods     String[]

  openingHours       Json?
  socialLinks        Json?

  latitude           Decimal? @db.Decimal(10, 7)
  longitude          Decimal? @db.Decimal(10, 7)

  memberships        BarbershopMembership[]
  barberBlocks       BarberBlock[]
  categories         BarbershopCategory[]
  services           BarbershopService[]
  appointments       BarbershopAppointment[]
  favoritedByUsers   FavoriteBarbershop[]
  weeklyInvoices     WeeklyInvoice[]

  createdAt          DateTime @default(now())

  @@map("barbershops")
}

model BarbershopMembership {
  id            String   @id @default(uuid())
  userId        String
  barbershopId  String
  role          MembershipRole
  isActive      Boolean @default(true)
  canManageBlocks Boolean @default(false)

  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  barbershop    Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())

  @@unique([userId, barbershopId])
}

model BarberProfile {
  id              String  @id @default(uuid())
  userId          String  @unique
  nickname        String?
  bio             String? @db.VarChar(500)
  avatarUrl       String? @db.Text
  weeklySchedule  Json?
  canManageBlocks Boolean @default(false)

  user            User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BarberBlock {
  id              String   @id @default(uuid())
  barbershopId    String
  barberUserId    String
  date            DateTime @db.Date
  startTime       String?  @db.VarChar(5)
  endTime         String?  @db.VarChar(5)
  allDay          Boolean  @default(false)
  reason          String?  @db.VarChar(200)

  createdByUserId String
  createdAt       DateTime @default(now())

  barbershop      Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  barberUser      User       @relation("BarberUserBlocks", fields: [barberUserId], references: [id], onDelete: Cascade)
  createdByUser   User       @relation("CreatedBlocks", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([barbershopId, barberUserId, date])
}

model BarbershopCategory {
  id           String   @id @default(uuid())
  barbershopId String
  name         String   @db.VarChar(60)
  description  String?  @db.VarChar(200)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  barbershop   Barbershop          @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  services     BarbershopService[]

  @@unique([barbershopId, name])
  @@index([barbershopId, isActive])
  @@map("barbershop_categories")
}

model BarbershopService {
  id              String   @id @default(uuid())
  barbershopId    String
  categoryId      String?
  name            String   @db.VarChar(80)
  description     String?  @db.VarChar(500)
  priceCents      Int
  durationMinutes Int
  isActive        Boolean  @default(true)
  avgRating       Decimal? @db.Decimal(3, 2)
  ratingCount     Int      @default(0)
  createdAt       DateTime @default(now())

  barbershop      Barbershop          @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  category        BarbershopCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  appointments    BarbershopAppointment[]

  @@unique([barbershopId, name])
  @@index([barbershopId, categoryId, isActive])
  @@map("barbershop_services")
}

model BarbershopAppointment {
  id               String            @id @default(uuid())
  barbershopId     String
  serviceId        String
  clientUserId     String
  barberUserId     String
  servicePriceCents Int
  serviceFeeCents   Int
  totalPriceCents   Int
  startAt          DateTime
  endAt            DateTime
  status           AppointmentStatus @default(PENDING)
  confirmedAt      DateTime?
  canceledAt       DateTime?
  canceledByUserId String?
  cancelReason     String?           @db.VarChar(300)
  rejectedAt       DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  barbershop       Barbershop        @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  service          BarbershopService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  clientUser       User              @relation("ClientAppointments", fields: [clientUserId], references: [id], onDelete: Cascade)
  barberUser       User              @relation("BarberAppointments", fields: [barberUserId], references: [id], onDelete: Cascade)
  canceledByUser   User?             @relation("CanceledByUser", fields: [canceledByUserId], references: [id], onDelete: SetNull)
  weeklyInvoiceItems WeeklyInvoiceAppointment[]

  @@index([barbershopId, startAt])
  @@index([barberUserId, startAt])
  @@index([clientUserId, startAt])
  @@index([status, startAt])
  @@map("barbershop_appointments")
}

model WeeklyInvoice {
  id                String              @id @default(uuid())
  barbershopId      String
  periodStart       DateTime            @db.Date
  periodEnd         DateTime            @db.Date
  dueAt             DateTime
  status            FinanceInvoiceStatus @default(OPEN)
  totalAppointments Int                 @default(0)
  totalFeesCents    Int                 @default(0)
  paidAt            DateTime?
  notes             String?             @db.Text
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  barbershop        Barbershop          @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  items             WeeklyInvoiceAppointment[]

  @@unique([barbershopId, periodStart, periodEnd])
  @@index([barbershopId, status, dueAt])
  @@index([barbershopId, periodStart, periodEnd])
  @@map("weekly_invoices")
}

model WeeklyInvoiceAppointment {
  id            String                @id @default(uuid())
  invoiceId     String
  appointmentId String                @unique
  createdAt     DateTime              @default(now())

  invoice       WeeklyInvoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  appointment   BarbershopAppointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@unique([invoiceId, appointmentId])
  @@index([appointmentId])
  @@map("weekly_invoice_appointments")
}

model FavoriteBarbershop {
  id           String   @id @default(uuid())
  userId       String
  barbershopId String
  createdAt    DateTime @default(now())

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)

  @@unique([userId, barbershopId])
  @@index([userId, createdAt])
  @@index([barbershopId, createdAt])
  @@map("favorite_barbershops")
}

enum MembershipRole {
  OWNER
  BARBER
}

enum BarbershopStatus {
  EM_CONFIGURACAO
  ATIVA
  SUSPENSA
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum OnboardingIntent {
  CLIENT
  OWNER
}

enum OnboardingStatus {
  PENDING
  DONE
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELED
  REJECTED
  COMPLETED
}

enum FinancialStatus {
  ACTIVE
  BLOCKED
}

enum FinanceInvoiceStatus {
  OPEN
  PAID
  OVERDUE
  VOID
}
